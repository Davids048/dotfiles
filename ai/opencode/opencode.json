{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "xhigh",
            "serviceTier": "priority"
          },
          "variants": {
            "xhigh": {
              "reasoningEffort": "xhigh",
              "serviceTier": "priority"
            },
            "fast": {
              "reasoningEffort": "xhigh",
              "serviceTier": "priority"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "wandb": {
      "type": "remote",
      "url": "https://mcp.withwandb.com/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:WANDB_API_KEY}"
      }
    }
  },
  "plugin": [
    [
      "file:///home/hal-jundas/opencode-team-plugin/src/index.ts",
      {
        "stateRoot": "/home/hal-jundas/.local/share/opencode-team-plugin"
      }
    ]
  ],
  "lsp": {
    "bash": {
      "command": [
        "/home/hal-jundas/.nvm/versions/node/v22.20.0/bin/node",
        "/home/hal-jundas/.config/opencode/node_modules/bash-language-server/out/cli.js",
        "start"
      ],
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".ksh"
      ]
    },
    "pyright": {
      "command": [
        "/home/hal-jundas/.nvm/versions/node/v22.20.0/bin/node",
        "/home/hal-jundas/.config/opencode/node_modules/pyright/langserver.index.js",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "yaml-ls": {
      "command": [
        "/home/hal-jundas/.nvm/versions/node/v22.20.0/bin/node",
        "/home/hal-jundas/.config/opencode/node_modules/yaml-language-server/bin/yaml-language-server",
        "--stdio"
      ],
      "extensions": [
        ".yaml",
        ".yml"
      ]
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "agent": {
    "team-lead": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "fast",
      "options": {
        "reasoningEffort": "xhigh",
        "serviceTier": "priority"
      },
      "description": "Orchestrates plugin team agents, delegates implementation, and reports progress to the user.",
      "prompt": "You are the Team Lead for OpenCode agent teams. Your main job is to orchestrate work, not to do the implementation yourself. For non-trivial work, create or reuse a team, spawn teammates with team_spawn_member, assign clear slices, and wait for their team_send_message reports. Delegate implementation, investigation, and verification to teammates so work stays isolated in separate sessions and saves lead-session context. Communicate progress and decisions to the user. Only do delegated implementation yourself when a teammate is blocked, unavailable, or the user explicitly asks you to take over.",
      "permission": {
        "*": "allow",
        "wandb_*": "ask",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": "allow",
        "call_omo_agent": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "git reset --hard*": "ask",
          "git clean*": "ask",
          "rm -rf*": "ask",
          "rm -fr*": "ask",
          "sudo *": "ask",
          "shutdown*": "ask",
          "reboot*": "ask"
        }
      }
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "fast",
      "options": {
        "reasoningEffort": "xhigh",
        "serviceTier": "priority"
      },
      "permission": {
        "*": "allow",
        "wandb_*": "ask",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": "allow",
        "call_omo_agent": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "git reset --hard*": "ask",
          "git clean*": "ask",
          "rm -rf*": "ask",
          "rm -fr*": "ask",
          "sudo *": "ask",
          "shutdown*": "ask",
          "reboot*": "ask"
        }
      }
    },
    "plan": {
      "mode": "all"
    },
    "explore": {
      "mode": "all",
      "model": "openai/gpt-5.5",
      "variant": "fast",
      "options": {
        "reasoningEffort": "xhigh",
        "serviceTier": "priority"
      },
      "permission": {
        "*": "allow",
        "wandb_*": "ask",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": "allow",
        "call_omo_agent": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "git reset --hard*": "ask",
          "git clean*": "ask",
          "rm -rf*": "ask",
          "rm -fr*": "ask",
          "sudo *": "ask",
          "shutdown*": "ask",
          "reboot*": "ask"
        }
      }
    },
    "general": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "fast",
      "options": {
        "reasoningEffort": "xhigh",
        "serviceTier": "priority"
      },
      "permission": {
        "*": "allow",
        "wandb_*": "ask",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": "allow",
        "call_omo_agent": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "git reset --hard*": "ask",
          "git clean*": "ask",
          "rm -rf*": "ask",
          "rm -fr*": "ask",
          "sudo *": "ask",
          "shutdown*": "ask",
          "reboot*": "ask"
        }
      }
    }
  }
}
